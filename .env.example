# Supabase Configuration
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: For server-side admin operations
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe – subscription billing
# Keys: https://dashboard.stripe.com/apikeys
# Webhook secret: https://dashboard.stripe.com/webhooks (add endpoint /api/webhooks/stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs – MenteIQ plans (get from Stripe Dashboard > Products)
# CHF prices
STRIPE_PRICE_PRO_MONTHLY_CHF=price_...
STRIPE_PRICE_PRO_YEARLY_CHF=price_...
STRIPE_PRICE_BUSINESS_MONTHLY_CHF=price_...
STRIPE_PRICE_BUSINESS_YEARLY_CHF=price_...
# EUR prices
STRIPE_PRICE_PRO_MONTHLY_EUR=price_...
STRIPE_PRICE_PRO_YEARLY_EUR=price_...
STRIPE_PRICE_BUSINESS_MONTHLY_EUR=price_...
STRIPE_PRICE_BUSINESS_YEARLY_EUR=price_...

# App URL (used for Stripe success/cancel redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI Model Configuration
# OpenAI (GPT-4, GPT-4o, GPT-4 Turbo)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic Claude (Claude 3.5 Sonnet, Claude 3 Opus, Claude 3 Haiku)
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google AI (Gemini 2.0 Flash, Gemini Pro)
# Get from https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=...

# Resend (Email service for portal invitations)
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_...

# Error tracking (optional)
# Get from https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=menteiq
SENTRY_AUTH_TOKEN=sntrys_...
